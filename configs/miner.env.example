# Copy this file to configs/miner.env and edit local values.
# Do not commit configs/miner.env.

# Use a self-custody Bitcoin mainnet address. Prefer bc1...
# Do not use an exchange deposit address, testnet address, or Lightning invoice.
BTC_ADDRESS=

# Worker name is public on Stratum / pool stats. Keep it anonymous.
WORKER_NAME=mac-cpu

# Official CKPool Bitcoin solo endpoint.
POOL_HOST=solo.ckpool.org
POOL_PORT=3333
POOL_PASSWORD=x

# Bitcoin double SHA-256.
ALGO=sha256d

# Conservative defaults for a Mac learning run.
THREADS=1
CPULIMIT_PERCENT=10
CPULIMIT_INCLUDE_CHILDREN=1
NICE_LEVEL=20
REQUIRE_AC_POWER=1
REQUIRE_PREFLIGHT=1
ALLOW_UNLIMITED_RUN=0
ALLOW_MULTI_THREAD=0

# Default throttle mode for macOS learning runs.
# duty-cycle is more reliable than cpulimit on modern macOS.
THROTTLE_MODE=duty-cycle
DUTY_ACTIVE_SECONDS=1
DUTY_IDLE_SECONDS=9

# Best-practice default: short bounded mainnet run.
# Set ALLOW_UNLIMITED_RUN=1 only if you intentionally want no time limit.
TIME_LIMIT_SECONDS=300

# Run logs are ignored by git.
LOG_DIR=logs
LOG_RETENTION=100

# Local build output.
MINER_BIN=vendor/cpuminer-multi/cpuminer

# Reproducibility pin for the known-good cpuminer source revision.
CPUMINER_REF=d2927ed23b1d0eacd067c320fce64e6610737adb
